generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipRole {
  admin
  moderator
  member
  guest
}

enum EventType {
  lecture
  deadline
  exam
  meeting
  other
}

enum ChatType {
  group
  private
  topic
}

model User {
  id             String          @id @default(uuid())
  name            String
  email           String          @unique
  passwordHash    String          @map("password_hash")
  createdAt       DateTime        @default(now()) @map("created_at")
  
  memberships     Membership[]
  createdGroups   Group[]         @relation("GroupCreatedBy")
  announcements   Announcement[]
  files           File[]
  events          Event[]
  polls           Poll[]
  votes           Vote[]
  chats           Chat[]          @relation("ChatCreatedBy")
  messages        Message[]
  refreshTokens   RefreshToken[]
  
  @@map("users")
}

model RefreshToken {
  id               String   @id @default(uuid())
  tokenHash        String   @unique @map("token_hash")
  userId           String   @map("user_id")
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now()) @map("created_at")
  expiresAt        DateTime @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  replacedByTokenId String? @map("replaced_by_token_id")
  createdByIp      String?  @map("created_by_ip")
  userAgent        String?  @map("user_agent")
  
  @@map("refresh_tokens")
}

model Group {
  id          String   @id @default(uuid())
  name        String
  description String?
  isPrivate   Boolean  @default(false) @map("is_private")
  createdById String   @map("created_by_id")
  createdBy   User     @relation("GroupCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")
  
  memberships   Membership[]
  announcements Announcement[]
  files         File[]
  events        Event[]
  polls         Poll[]
  chats         Chat[]
  
  @@map("groups")
}

model Membership {
  id        String         @id @default(uuid())
  userId    String         @map("user_id")
  groupId   String         @map("group_id")
  role      MembershipRole @default(member)
  joinedAt  DateTime       @default(now()) @map("joined_at")
  isActive  Boolean        @default(true) @map("is_active")
  
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  group     Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  
  @@unique([userId, groupId])
  @@map("memberships")
}

model Announcement {
  id          String   @id @default(uuid())
  groupId     String   @map("group_id")
  authorId    String   @map("author_id")
  title       String
  content     String
  isPinned    Boolean  @default(false) @map("is_pinned")
  isPublic    Boolean  @default(false) @map("is_public")
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  group       Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  author      User     @relation(fields: [authorId], references: [id])
  
  @@map("announcements")
}

model File {
  id          String   @id @default(uuid())
  groupId     String   @map("group_id")
  uploaderId  String   @map("uploader_id")
  name        String
  description String?
  filePath    String   @map("file_path")
  fileSize    Int      @map("file_size")
  mimeType    String   @map("mime_type")
  category    String?
  createdAt   DateTime @default(now()) @map("created_at")
  
  group       Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  uploader    User     @relation(fields: [uploaderId], references: [id])
  
  @@map("files")
}

model Event {
  id          String    @id @default(uuid())
  groupId     String    @map("group_id")
  creatorId   String    @map("creator_id")
  title       String
  description String?
  startAt     DateTime  @map("start_at")
  endAt       DateTime  @map("end_at")
  location    String?
  type        EventType @default(other)
  createdAt   DateTime  @default(now()) @map("created_at")
  
  group       Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  creator     User      @relation(fields: [creatorId], references: [id])
  
  @@map("events")
}

model Poll {
  id              String   @id @default(uuid())
  groupId         String   @map("group_id")
  creatorId       String   @map("creator_id")
  question        String
  isAnonymous     Boolean  @default(false) @map("is_anonymous")
  isMultipleChoice Boolean @default(false) @map("is_multiple_choice")
  expiresAt       DateTime? @map("expires_at")
  createdAt       DateTime @default(now()) @map("created_at")
  
  group           Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  creator        User     @relation(fields: [creatorId], references: [id])
  choices        Choice[]
  votes           Vote[]
  
  @@map("polls")
}

model Choice {
  id        String   @id @default(uuid())
  pollId    String   @map("poll_id")
  text      String
  order     Int      @default(0)
  
  poll      Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes     Vote[]
  
  @@map("choices")
}

model Vote {
  id        String   @id @default(uuid())
  pollId    String   @map("poll_id")
  choiceId  String   @map("choice_id")
  voterId   String   @map("voter_id")
  createdAt DateTime @default(now()) @map("created_at")
  
  poll      Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)
  choice    Choice   @relation(fields: [choiceId], references: [id], onDelete: Cascade)
  voter     User     @relation(fields: [voterId], references: [id])
  
  @@unique([pollId, voterId, choiceId])
  @@map("votes")
}

model Chat {
  id          String   @id @default(uuid())
  groupId     String   @map("group_id")
  title       String
  type        ChatType @default(group)
  isReadOnly  Boolean  @default(false) @map("is_read_only")
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  
  group       Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdBy   User     @relation("ChatCreatedBy", fields: [createdById], references: [id])
  messages    Message[]
  
  @@map("chats")
}

model Message {
  id          String   @id @default(uuid())
  chatId      String   @map("chat_id")
  authorId    String   @map("author_id")
  content     String
  attachments Json?    @default("[]")
  createdAt   DateTime @default(now()) @map("created_at")
  editedAt    DateTime? @map("edited_at")
  isDeleted   Boolean  @default(false) @map("is_deleted")
  
  chat        Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  author      User     @relation(fields: [authorId], references: [id])
  
  @@map("messages")
}

