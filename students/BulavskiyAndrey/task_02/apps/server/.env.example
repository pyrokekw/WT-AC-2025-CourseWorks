# Database
# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/group_organizer_db?schema=public"

# JWT Secrets
# ВАЖНО: Генерируйте случайные строки для production!
# Можно использовать: openssl rand -base64 32
JWT_ACCESS_SECRET="dev_access_secret_change_in_prod"
JWT_REFRESH_SECRET="dev_refresh_secret_change_in_prod"

# JWT Token TTL
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# CORS
# Разрешенные источники (через запятую для нескольких)
CORS_ORIGIN="http://localhost:5173"

# Server Configuration
SERVER_PORT=3000
SERVER_HOST=0.0.0.0
NODE_ENV=development

# Logging
LOG_LEVEL=info
# Возможные значения: error, warn, info, debug

# Redis (опционально, для кэширования)
# Если не указан, кэширование будет отключено
REDIS_URL="redis://localhost:6379"

# Cache TTL (в секундах)
CACHE_TTL_SHORT=30
CACHE_TTL_MEDIUM=300
CACHE_TTL_LONG=3600

# Cookies
COOKIE_SECURE=false
# true для HTTPS, false для HTTP (development)
COOKIE_SAMESITE=lax
# Возможные значения: lax, strict, none
