# Backend environment example
PORT=4000
CORS_ORIGIN=http://localhost:5173
JWT_ACCESS_SECRET=change-access
JWT_REFRESH_SECRET=change-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
# Optional fallback legacy secret (not required if access/refresh secrets are set)
JWT_SECRET=change-me

# PostgreSQL (Prisma)
# Example: postgresql://USER:PASSWORD@HOST:5432/DB?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/help_nearby?schema=public
