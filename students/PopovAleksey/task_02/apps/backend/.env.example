# Backend
PORT=3001

# PostgreSQL (Prisma)
# пример: postgresql://postgres:postgres@localhost:5432/room_booking?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/room_booking?schema=public

# CORS
CORS_ORIGIN=http://localhost:5173

# JWT
JWT_ACCESS_SECRET=dev_access_secret_change_me_please_32chars_minimum
JWT_REFRESH_SECRET=dev_refresh_secret_change_me_please_32chars_minimum
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
COOKIE_DOMAIN=
