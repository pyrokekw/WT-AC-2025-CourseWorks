{
  "name": "taskmanager",
  "version": "1.0.0",
  "private": true,
  "description": "Task Manager - Full-stack project management application",
  "workspaces": [
    "apps/*",
    "infra"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "npm run dev --workspace=server",
    "dev:web": "npm run dev --workspace=web",
    "build": "npm run build --workspaces",
    "build:server": "npm run build --workspace=server",
    "build:web": "npm run build --workspace=web",
    "test": "npm run test --workspaces",
    "test:server": "npm run test --workspace=server",
    "lint": "npm run lint --workspaces",
    "lint:fix": "npm run lint:fix --workspaces",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "db:migrate": "npm run migrate --workspace=server",
    "db:seed": "npm run seed --workspace=server",
    "db:reset": "npm run db:reset --workspace=server",
    "infra:migrate": "npm run start:migrate --workspace=infra",
    "infra:seed": "npm run start:seed --workspace=infra",
    "prepare": "husky install"
  },
  "keywords": [
    "task-manager",
    "project-management",
    "kanban",
    "react",
    "nodejs",
    "postgresql",
    "typescript"
  ],
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.5",
    "concurrently": "^8.2.2",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}